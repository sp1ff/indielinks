if [ -e "admin/cargo-test-${name}" ]; then
    echo "Warning: overwriting existing file 'admin/cargo-test-${name}'" >&2
fi
sed "s/__STACK__/${name}/g" <<'CARGO_EOF' > "admin/cargo-test-${name}"
#!/usr/bin/env bash
set -euo pipefail
# Pre-build all the tests; that way, integration test scripts won't hang-up
# waiting for services to come up.
time limitcpu /home/mgh/.cargo/bin/cargo -f -l 800 -- test --no-run
INDIELINKS_CACHE_CLUSTER_TESTS_CONFIG=conf/cache-cluster-tests-__STACK__.toml \
INDIELINKS_CACHE_TESTS_CONFIG=conf/cache-tests-__STACK__.toml \
INDIELINKS_SMOKE_TESTS_CONFIG=conf/smoke-tests-__STACK__.toml \
INDIELINKS_BACKGROUND_TASK_TESTS_CONFIG=conf/background-task-tests-__STACK__.toml \
time limitcpu /home/mgh/.cargo/bin/cargo -f -l 800 -- test
CARGO_EOF
chmod +x "admin/cargo-test-${name}"

# ---------------------------------------------------------------------------
# .agents/bin/agent-sign-off  (executable; uses sed to avoid heredoc escaping)
# ---------------------------------------------------------------------------

if [ -e ".agents/bin/agent-sign-off" ]; then
    echo "Warning: overwriting existing file '.agents/bin/agent-sign-off'" >&2
fi
sed "s/__STACK__/${name}/g" <<'SIGNOFF_EOF' > ".agents/bin/agent-sign-off"
#!/usr/bin/env bash

# Agent sign-off script for the '__STACK__' stack.
# Shamelessly stolen from: <https://gist.github.com/dhh/c5051aae633ff91bc4ce30528e4f0b60>
set -e
SECONDS=0
SHA=$(git rev-parse HEAD)

GREEN=32; RED=31; BLUE=34
announce() { echo -e "\033[0;$2m$1\033[0m"; }
run() {
  local SPLIT=$SECONDS
  announce "\nRun $1" $BLUE
  eval "$1"
  local INTERVAL=$((SECONDS-SPLIT))
  announce "Completed $1 in $INTERVAL seconds" $GREEN
}

announce "Attempting agent sign-off on indielinks $SHA." $GREEN

run "admin/run-linters"
run "admin/cargo-test-__STACK__"

announce "Signed off on indielinks $SHA in $SECONDS seconds" $GREEN
SIGNOFF_EOF
chmod +x ".agents/bin/agent-sign-off"

echo "Done. Stack '${name}' created successfully."
echo ""
echo "Next steps:"
echo "  1. Start ScyllaDB:   cd infra && ./scylla-up ${name}.env"
echo "  2. Run tests:        admin/cargo-test-${name}"
