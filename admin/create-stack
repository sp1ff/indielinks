#!/usr/bin/env bash
VERSION=0.0.1

help=
nargs=0
prev_option=
verbose=
version=
for option
do
    if test -n "$prev_option"; then
        eval $prev_option=\$option
        prev_option=
        nargs=$(($nargs+1))
        continue
    fi

    case $option in
        *=?*) optarg=$(expr "X$option" : '[^=]*=\(.*\)') ;;
        *=)   optarg= ;;
        *)    optarg=yes ;;
    esac

    case $option in
        -h | --he | --hel | --help)
            nargs=$(($nargs+1)); help=yes;;
        -v | --verb | --verbose)
            nargs=$(($nargs+1)); verbose=yes;;
        -V | --vers | --version)
            nargs=$(($nargs+1)); version=yes;;
        -*)
            cat >&2 <<USAGE
Unrecognized option '$option'.
Try 'create-stack --help' for more information.
USAGE
            exit 2;;
        *)
            break;;
    esac
done

shift $nargs
# $@ now contains the arguments, $# the number of arguments

if test -n "${help}"; then
    cat <<HELP
create-stack -- Create configuration files for a new indielinks integration test stack

Usage:

    create-stack [OPTION...] NAME PARAMS-FILE

Arguments:

    NAME         Stack name (lowercase letters, digits, hyphens, underscores). May not
                 be 'indielinks'.

    PARAMS-FILE  Shell-sourceable file supplying:
                   APP_PORT_BASE          Base port for the 5-node indielinksd cluster.
                                          Node i gets ports base+3i (public),
                                          base+3i+1 (private), base+3i+2 (gRPC).
                   HAPROXY_PORT           HAProxy/load-balancer port
                   SCYLLA_NATIVE_BASE     First ScyllaDB native-protocol port
                                          (three consecutive ports are used)
                   SCYLLA_ALTERNATOR_BASE First ScyllaDB Alternator-protocol port
                                          (three consecutive ports are used)
                   CACHE_PORT_BASE        Base port for the 5-node cache binary cluster
                   SCYLLA_SUBNET          Docker bridge subnet in CIDR notation
                                          (e.g. 172.13.0.0/24). Node addresses
                                          will be <prefix>.2, .3, .4.
                   SCYLLA_NODE_BASE       Numeric suffix of the first ScyllaDB Docker
                                          container (three consecutive suffixes are used)

Options:

    -h, --help     Print this message & exit
    -V, --version  Print this script's version & exit
    -v, --verbose  Produce verbose output

Generated files:

    infra/<NAME>.env
    conf/indielinksd-<NAME>-scylla.toml
    conf/indielinksd-<NAME>-alternator.toml
    conf/<NAME>/indielinksd-scylla-{0..4}.toml
    conf/<NAME>/indielinksd-alternator-{0..4}.toml
    tests-indielinks/conf/smoke-tests-<NAME>.toml
    tests-indielinks/conf/cache-tests-<NAME>.toml
    tests-indielinks/conf/background-task-tests-<NAME>.toml
    tests-indielinks-cache/conf/cache-cluster-tests-<NAME>.toml
    admin/cargo-test-<NAME>
    .agents/bin/agent-sign-off

HELP
    exit 0
fi

if test -n "${version}"; then
    echo "create-stack ${VERSION}"
    exit 0
fi

if [ $# -ne 2 ]; then
    cat >&2 <<USAGE
Usage: create-stack [OPTION...] NAME PARAMS-FILE
Try 'create-stack --help' for more information.
USAGE
    exit 2
fi

set -euo pipefail
if test -n "${verbose}"; then
    set -x
fi

name="$1"
params_file="$2"

# Validate name
if ! echo "${name}" | grep -qE '^[a-z0-9][a-z0-9_-]*$'; then
    cat >&2 <<ERR
Error: NAME must match [a-z0-9][a-z0-9_-]* (got '${name}').
Try 'create-stack --help' for more information.
ERR
    exit 2
fi
if [ "${name}" = "default" ] || [ "${name}" = "indielinks" ]; then
    echo "Error: NAME '${name}' is reserved." >&2
    exit 2
fi

# Source the params file
source "${params_file}"

required_vars=(APP_PORT_BASE HAPROXY_PORT SCYLLA_NATIVE_BASE SCYLLA_ALTERNATOR_BASE
               CACHE_PORT_BASE SCYLLA_SUBNET SCYLLA_NODE_BASE)
for var in "${required_vars[@]}"; do
    if [ -z "${!var:-}" ]; then
        echo "Error: required variable ${var} is not set in '${params_file}'." >&2
        exit 2
    fi
done

# Move to the repo root (this script lives in admin/)
here=$(dirname "$(realpath "$0")")
root=$(dirname "${here}")
cd "${root}"

# ---------------------------------------------------------------------------
# Derive all port and subnet values before writing any file
# ---------------------------------------------------------------------------

subnet_prefix=$(echo "${SCYLLA_SUBNET}" | sed 's/\.[0-9]*\/[0-9]*$//')
node1_suffix=$((SCYLLA_NODE_BASE))
node2_suffix=$((SCYLLA_NODE_BASE + 1))
node3_suffix=$((SCYLLA_NODE_BASE + 2))
node1_addr="${subnet_prefix}.2"
node2_addr="${subnet_prefix}.3"
node3_addr="${subnet_prefix}.4"

scylla_native_1=$((SCYLLA_NATIVE_BASE))
scylla_native_2=$((SCYLLA_NATIVE_BASE + 1))
scylla_native_3=$((SCYLLA_NATIVE_BASE + 2))

scylla_alt_1=$((SCYLLA_ALTERNATOR_BASE))
scylla_alt_2=$((SCYLLA_ALTERNATOR_BASE + 1))
scylla_alt_3=$((SCYLLA_ALTERNATOR_BASE + 2))

# Per-Raft-node ports (indexed 0-4)
declare -a pub prv grpc
for i in 0 1 2 3 4; do
    pub[$i]=$((APP_PORT_BASE + 3*i))
    prv[$i]=$((APP_PORT_BASE + 3*i + 1))
    grpc[$i]=$((APP_PORT_BASE + 3*i + 2))
done

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# write_file PATH: reads content from stdin, warns and overwrites if PATH exists
write_file() {
    local path="$1"
    if [ -e "${path}" ]; then
        echo "Warning: overwriting existing file '${path}'" >&2
    fi
    cat > "${path}"
}

mkdir -p "conf/${name}" ".agents/bin"

echo "Generating stack '${name}'..."

