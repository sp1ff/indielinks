# docker compose env file for ${name} stack
SCYLLA_SUBNET="${SCYLLA_SUBNET}"
SCYLLA_NODE_1=${node1_suffix}
SCYLLA_NODE_2=${node2_suffix}
SCYLLA_NODE_3=${node3_suffix}
SCYLLA_NATIVE_PORT_1=${scylla_native_1}
SCYLLA_NATIVE_PORT_2=${scylla_native_2}
SCYLLA_NATIVE_PORT_3=${scylla_native_3}
SCYLLA_ALTERNATOR_PORT_1=${scylla_alt_1}
SCYLLA_ALTERNATOR_PORT_2=${scylla_alt_2}
SCYLLA_ALTERNATOR_PORT_3=${scylla_alt_3}
SCYLLA_NODE_1_ADDRESS=${node1_addr}
SCYLLA_NODE_2_ADDRESS=${node2_addr}
SCYLLA_NODE_3_ADDRESS=${node3_addr}
EOF

