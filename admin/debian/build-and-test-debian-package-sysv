#!/usr/bin/env bash

# This script will bind mount the project directory into a Debian container,
# build a Debian package, test it in the container (installing indielinks as a
# free-standing Sys V daemon), and leave the package in `target/debian`.

# indielinks builds the Debian package via cargo-deb, which can run on
# pretty-much any Linux machine, but I prefer to build it in a proper Debian
# environment, where I can install `dpkg`, `dpkg-dev` & `liblzma-dev` which are
# optional dependencies that can add some capabilities (as I understand it).

set -ex

here=$(dirname $(realpath $0))
project=${here}/..
cd ${here}
docker build -t indielinks-debian:latest \
       -f Dockerfile \
       --label "indielinks-debian" \
       --build-arg UID="$(id -u)" \
       --build-arg GID="$(id -g)" \
       .

name=debian-packaging
docker compose -f compose.yaml -f debian-packaging.yaml --project-name $name up -d
echo "Waiting on 'host'..."
docker compose -f compose.yaml -f debian-packaging.yaml --project-name $name wait host
status=$?
echo "Waiting on 'host'...done($status)."
docker logs debian-packaging-host-1
docker compose -f compose.yaml -f debian-packaging.yaml --project-name $name down

exit $status

